{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "local-doc-viewer",
  "mainBinaryName": "local-doc-viewer",
  "version": "0.1.3",
  "identifier": "com.localdocviewer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "local-doc-viewer",
        "width": 1100,
        "height": 760
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/local-doc-viewer/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "fileAssociations": [
      {
        "ext": ["ofd"],
        "mimeType": "application/x-ofd",
        "role": "Viewer"
      },
      {
        "ext": ["pdf"],
        "mimeType": "application/pdf",
        "role": "Viewer"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
